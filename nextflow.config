manifest {
    name        = 'bacflow'
    version     = '1.0.0'
    description = 'Long-Read Genome Assembly Pipeline'
    author      = 'jlpitta'
    nextflowVersion = '>=23.04.0'
}

params {
    // Input
    samplesheet     = null
    long_reads      = null
    short_reads_1   = null
    short_reads_2   = null
    sample_name     = 'sample'
    genome_size     = null

    // Mode
    mode            = 'denovo'

    // Polishing
    use_racon         = false
    polisher          = 'polypolish'  // polypolish (default), nextpolish, none
    nextpolish_rounds = 1             // apenas para --polisher nextpolish

    // Platform
    platform        = 'mgicyclone'
    medaka_model    = null   // definido pelo platform; sobrescreve com --medaka_model
    flye_mode       = null   // definido pelo platform; sobrescreve com --flye_mode

    // Filtering
    min_quality     = 10
    min_length      = 500
    downsample      = 0

    // Reference
    reference       = null

    // QC de montagem (BUSCO — só roda quando reference == null)
    busco_lineage   = 'bacteria_odb10'

    // QC de montagem (CheckM2 — completude + contaminação, roda sempre)
    checkm2_db      = "${System.getenv('HOME')}/checkm2_db/CheckM2_database/uniref100.KO.1.dmnd"

    // Resources
    t               = 8
    outdir          = 'results'

    // Help
    help            = false
}

conda.enabled  = true
conda.useMamba = true

executor {
    name = 'local'
    cpus = Math.min(params.t as int, Runtime.runtime.availableProcessors())
}

process {
    cache = 'lenient'

    withLabel: 'process_low' {
        cpus = { Math.max(1, (Math.min(params.t as int, Runtime.runtime.availableProcessors()) / 4).toInteger()) }
    }
    withLabel: 'process_medium' {
        cpus = { Math.max(1, (Math.min(params.t as int, Runtime.runtime.availableProcessors()) / 2).toInteger()) }
    }
    withLabel: 'process_high' {
        cpus = { Math.min(params.t as int, Runtime.runtime.availableProcessors()) }
    }
}

profiles {
    conda      { conda.useMamba = false }
    mamba      { /* default */ }
    micromamba { conda.mambaBin = 'micromamba' }
}
